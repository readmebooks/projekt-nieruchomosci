{"data": {"conn_name": "model.dbt_transformation.avg_price_by_city", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "ecc9c5c6dde7ef2ee47659d7f90e20a4316a3d15fc5b86916cd9b656680d7b34", "node_finished_at": "", "node_name": "avg_price_by_city", "node_path": "avg_price_by_city.sql", "node_relation": {"alias": "avg_price_by_city", "database": "nieruchomosci_uk", "relation_name": "\"nieruchomosci_uk\".\"main\".\"avg_price_by_city\"", "schema": "main"}, "node_started_at": "2026-04-04T18:35:15.424579", "node_status": "executing", "resource_type": "model", "unique_id": "model.dbt_transformation.avg_price_by_city"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"dbt_transformation\", \"target_name\": \"dev\", \"node_id\": \"model.dbt_transformation.avg_price_by_city\"} */\n\n  \n  create view \"nieruchomosci_uk\".\"main\".\"avg_price_by_city__dbt_tmp\" as (\n    \n\n/* Gold layer model: Aggregating average property prices per city.\n  This view is optimized for reporting and data visualization.\n*/\n\nSELECT \n    city,\n    sale_year,\n    round(avg(price), 2) as average_price,\n    count(*) as total_transactions\nFROM \"nieruchomosci_uk\".\"main\".\"stg_uk_sales\"\nGROUP BY city, sale_year\nORDER BY sale_year DESC, average_price DESC\n  );\n"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "108d4571-bfd9-4139-aad3-b0053aeec2fa", "level": "debug", "msg": "On model.dbt_transformation.avg_price_by_city: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"dbt_transformation\", \"target_name\": \"dev\", \"node_id\": \"model.dbt_transformation.avg_price_by_city\"} */\n\n  \n  create view \"nieruchomosci_uk\".\"main\".\"avg_price_by_city__dbt_tmp\" as (\n    \n\n/* Gold layer model: Aggregating average property prices per city.\n  This view is optimized for reporting and data visualization.\n*/\n\nSELECT \n    city,\n    sale_year,\n    round(avg(price), 2) as average_price,\n    count(*) as total_transactions\nFROM \"nieruchomosci_uk\".\"main\".\"stg_uk_sales\"\nGROUP BY city, sale_year\nORDER BY sale_year DESC, average_price DESC\n  );\n", "name": "SQLQuery", "pid": 13448, "thread": "Thread-1 (worker)", "ts": "2026-04-04T18:35:15.497151Z"}}
