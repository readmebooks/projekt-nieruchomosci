{"data": {"conn_name": "model.dbt_transformation.stg_uk_sales", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "946184fcc333afb89c11119fedfd0956bcf2ea186a552294f97c09d08a822e0d", "node_finished_at": "", "node_name": "stg_uk_sales", "node_path": "staging\\stg_uk_sales.sql", "node_relation": {"alias": "stg_uk_sales", "database": "nieruchomosci_uk", "relation_name": "\"nieruchomosci_uk\".\"main\".\"stg_uk_sales\"", "schema": "main"}, "node_started_at": "2026-04-10T19:41:38.653873", "node_status": "executing", "resource_type": "model", "unique_id": "model.dbt_transformation.stg_uk_sales"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"dbt_transformation\", \"target_name\": \"dev\", \"node_id\": \"model.dbt_transformation.stg_uk_sales\"} */\n\n  \n    \n    \n\n    create  table\n      \"nieruchomosci_uk\".\"main\".\"stg_uk_sales__dbt_tmp\"\n  \n    as (\n      \n\n/* Staging model for UK property sales data.\n  Loads partitioned CSV files from the local data directory.\n*/\n\nSELECT \n    column00 as id,\n    CAST(column01 AS INTEGER) as price,\n    CAST(substring(column02, 1, 10) AS DATE) as sale_date,\n    column11 as city,\n    column13 as county,\n    sale_year -- this column is automatically added by DuckDB from the folder structure\nFROM read_csv_auto('../data/parts/*/*.csv', all_varchar=True)\nWHERE CAST(column01 AS INTEGER) > 0\n    );\n  \n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "fa20bdb1-c806-42f4-8cfd-4ee900e5ceff", "level": "debug", "msg": "On model.dbt_transformation.stg_uk_sales: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"dbt_transformation\", \"target_name\": \"dev\", \"node_id\": \"model.dbt_transformation.stg_uk_sales\"} */\n\n  \n    \n    \n\n    create  table\n      \"nieruchomosci_uk\".\"main\".\"stg_uk_sales__dbt_tmp\"\n  \n    as (\n      \n\n/* Staging model for UK property sales data.\n  Loads partitioned CSV files from the local data directory.\n*/\n\nSELECT \n    column00 as id,\n    CAST(column01 AS INTEGER) as price,\n    CAST(substring(column02, 1, 10) AS DATE) as sale_date,\n    column11 as city,\n    column13 as county,\n    sale_year -- this column is automatically added by DuckDB from the folder structure\nFROM read_csv_auto('../data/parts/*/*.csv', all_varchar=True)\nWHERE CAST(column01 AS INTEGER) > 0\n    );\n  \n  ", "name": "SQLQuery", "pid": 1360, "thread": "Thread-1 (worker)", "ts": "2026-04-10T19:41:38.794426Z"}}
