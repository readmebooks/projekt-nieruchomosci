{"data": {"conn_name": "model.dbt_transformation.avg_price_by_city", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "ecc9c5c6dde7ef2ee47659d7f90e20a4316a3d15fc5b86916cd9b656680d7b34", "node_finished_at": "", "node_name": "avg_price_by_city", "node_path": "avg_price_by_city.sql", "node_relation": {"alias": "avg_price_by_city", "database": "nieruchomosci_uk", "relation_name": "\"nieruchomosci_uk\".\"main\".\"avg_price_by_city\"", "schema": "main"}, "node_started_at": "2026-04-04T17:58:22.119499", "node_status": "executing", "resource_type": "model", "unique_id": "model.dbt_transformation.avg_price_by_city"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"dbt_transformation\", \"target_name\": \"dev\", \"node_id\": \"model.dbt_transformation.avg_price_by_city\"} */\n\n  \n  create view \"nieruchomosci_uk\".\"main\".\"avg_price_by_city__dbt_tmp\" as (\n    \n\n/* Gold layer model: Aggregating average property prices per city.\n  This view is optimized for reporting and data visualization.\n*/\n\nSELECT \n    city,\n    sale_year,\n    round(avg(price), 2) as average_price,\n    count(*) as total_transactions\nFROM \"nieruchomosci_uk\".\"main\".\"stg_uk_sales\"\nGROUP BY city, sale_year\nORDER BY sale_year DESC, average_price DESC\n  );\n"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "6472a3a1-eb76-4635-b3b1-9bf50d6eaf3f", "level": "debug", "msg": "On model.dbt_transformation.avg_price_by_city: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"dbt_transformation\", \"target_name\": \"dev\", \"node_id\": \"model.dbt_transformation.avg_price_by_city\"} */\n\n  \n  create view \"nieruchomosci_uk\".\"main\".\"avg_price_by_city__dbt_tmp\" as (\n    \n\n/* Gold layer model: Aggregating average property prices per city.\n  This view is optimized for reporting and data visualization.\n*/\n\nSELECT \n    city,\n    sale_year,\n    round(avg(price), 2) as average_price,\n    count(*) as total_transactions\nFROM \"nieruchomosci_uk\".\"main\".\"stg_uk_sales\"\nGROUP BY city, sale_year\nORDER BY sale_year DESC, average_price DESC\n  );\n", "name": "SQLQuery", "pid": 26188, "thread": "Thread-1 (worker)", "ts": "2026-04-04T17:58:22.182544Z"}}
